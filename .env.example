# Copy this file to .env and fill in real values for your environment.

# Google BigQuery
PROJECT_ID=your-gcp-project-id
DATASET_ID=healthcare_core
BIGQUERY_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=.credentials/gcp/bigquery-loader.sa.dev.json

# Optional SQL Server source configuration
DB_HOST=localhost
DB_PORT=1433
DB_NAME=your_database_name
DB_INSTANCE=
DB_USER=your_username
DB_PASSWORD=your_password
